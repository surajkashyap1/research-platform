# =====================================================================
# Copy this file to `.env.local` and fill in values from your Supabase
# project dashboard (Project Settings → Data API / Database).
# `.env.local` is git-ignored — never commit real secrets.
# =====================================================================

# Supabase Data API (Project Settings → Data API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Server-only: Postgres connection string for Drizzle.
# Use the *Transaction pooler* connection string (port 6543) from
# Project Settings → Database → Connection string → "Transaction" mode.
# Remember to URL-encode special characters in your password.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-ref:YOUR-DB-PASSWORD@aws-0-eu-west-2.pooler.supabase.com:6543/postgres"

# Server-only: service role key (NEVER expose to the browser).
# Used for privileged server-side operations that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional (Phase 4 email notifications via Resend). Leave unset to keep
# in-app notifications only — email is a no-op until both are provided.
# RESEND_API_KEY="re_..."
# RESEND_FROM="Incipit <notifications@yourdomain.com>"
# NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# Optional (Phase 7). Comma-separated admin emails who can view /admin metrics.
# Unset = nobody can access it (returns 404).
# ADMIN_EMAILS="you@example.com"

# Optional (Phase 7). If set, the weekly keepalive cron requires this as a
# Bearer token. Set the same value in Vercel's Cron environment.
# CRON_SECRET="some-long-random-string"
